# ===========================================
# GIFT OF GRACE - ENVIRONMENT CONFIGURATION
# ===========================================

# ------------------------------------------
# CHATBOT API CONFIGURATION
# ------------------------------------------

# Hugging Face Space URL (Production - Cloud LLM)
# This connects to the RAG API with multiple LLM support:
# - Gemini (default)
# - OpenAI
# - OpenRouter
# - DeepSeek
VITE_GEMINI_API_URL=https://gracetouchph-ctrl-giftofgrace-rag-api.hf.space/chat

# RASA Server (Local Development only)
VITE_RASA_API_URL=http://localhost:5005/webhooks/rest/webhook

# Chat Mode Options:
# - 'gemini'  : Use Hugging Face API (Gemini/OpenAI/OpenRouter) - RECOMMENDED FOR PRODUCTION
# - 'rasa'    : Use local RASA server
# - 'auto'    : Try RASA first, fallback to Gemini
VITE_CHAT_MODE=gemini

# ------------------------------------------
# ADMIN API CONFIGURATION
# ------------------------------------------
# For local development:
# VITE_ADMIN_API_URL=http://localhost:8001
# For production (Hugging Face Spaces):
VITE_ADMIN_API_URL=https://gracetouchph-ctrl-giftofgrace-rag-api.hf.space
